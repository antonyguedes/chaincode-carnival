# Cyber Arena: Universal LLM Configurator
# Set your providers: "gemini", "groq", "ollama", "openai", "anthropic", "cohere", "deepseek", "mistralai", "openrouter"

# 1. Analyzer Agent
ANALYZER_PROVIDER="ollama"
ANALYZER_MODEL="orca-mini"
ANALYZER_API_KEY=""               # Optional for local ollama, REQUIRED for all cloud APIs

# 2. Red Team Agent (Exploiter)
REDTEAM_PROVIDER="gemini"
REDTEAM_MODEL="gemini-1.5-pro"
REDTEAM_API_KEY="YOUR_API_KEY_HERE"

# 3. Blue Team Agent (Fixer)
BLUETEAM_PROVIDER="groq"
BLUETEAM_MODEL="llama3-70b-8192"
BLUETEAM_API_KEY="YOUR_API_KEY_HERE"

# 4. Skeptic Agent (Judge)
SKEPTIC_PROVIDER="gemini"
SKEPTIC_MODEL="gemini-1.5-pro"
SKEPTIC_API_KEY="YOUR_API_KEY_HERE"

# Optional Global config overrides
OLLAMA_HOST="http://127.0.0.1:11434"
